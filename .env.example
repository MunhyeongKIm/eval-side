# Database - Neon PostgreSQL or local Postgres
DATABASE_URL=postgresql://user:password@host:5432/eval_side

# GitHub - Personal access token for repo analysis (needs 'repo' scope for private repos)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini - Primary AI provider
# Get key at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# OpenRouter - Fallback AI provider
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# API Keys - Comma-separated list of valid API keys for authenticated access
# Authenticated users get relaxed rate limits (20 req/min vs 5 req/min)
# Leave empty to disable API key authentication
API_KEYS=
